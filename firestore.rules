rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each player owns exactly one progress document, keyed by their Firebase
    // Auth uid. Only that signed-in user may read or write it.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
