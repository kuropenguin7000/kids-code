# Copy this file to .env.local and fill in the values.

# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=change-me

# Google OAuth credentials — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (dev): http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
